{
  "name": "bi-tunnel",
  "version": "1.0.0",
  "description": "Bi-directional tunnel and proxy",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "build:css": "npx tailwindcss -i ./src/web/public/input.css -o ./src/web/public/tailwind.css --minify",
    "build:webui": "cd webui && npm run build",
    "build:app": "npx pkg . --out-path dist",
    "build": "npm run build:webui && npm run build:app",
    "dev:webui": "cd webui && npm run dev",
    "dev:backend": "node src/index.js"
  },
  "pkg": {
    "scripts": "src/**/*.js",
    "assets": [
      "src/web/public/**/*",
      "bin/xray.exe",
      "bin/xray",
      "bin/geoip.dat",
      "bin/geosite.dat",
      "bin/wintun.dll"
    ],
    "targets": [
      "node16-win-x64",
      "node16-linux-x64"
    ]
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-basic-auth": "^1.2.1",
    "geoip-lite": "^1.4.10",
    "ipaddr.js": "^2.1.0",
    "node-forge": "^1.4.0",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.38"
  }
}
